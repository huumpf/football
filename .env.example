# Copy to .env (git-ignored) and fill in to use the manual deploy: npm run deploy
# The CI deploy uses GitHub repo secrets instead (see DEPLOY.md), not this file.

FTP_HOST=ftp.your-host.example
FTP_USER=your-ftp-user
FTP_PASSWORD=your-ftp-password

# Remote web root as seen from the FTP login (trailing slash). Leave as / if the
# login already lands in the web root.
FTP_SERVER_DIR=/

# Use explicit FTPS over TLS when the host supports it (strongly recommended —
# plain FTP sends your password in cleartext).
FTP_SECURE=true
